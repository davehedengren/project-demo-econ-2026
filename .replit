run = "python -m src.main --port 8080"
entrypoint = "src/main.py"
modules = ["python-3.12"]

[env]
PYTHONUNBUFFERED = "1"

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[deployment]
run = ["python", "-m", "src.main", "--port", "8080"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m src.main --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
