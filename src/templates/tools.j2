{# Tool definitions for the career counselor chatbot #}
[
{% if has_profiles %}
    {
        "name": "semantic_search_careers",
        "description": "Search for careers using natural language descriptions of interests, skills, personality, or goals. This uses semantic matching — much better than keyword search for understanding what a student means. Use this as your PRIMARY search tool. Examples: 'I like helping people feel better', 'creative problem solving with technology', 'working outdoors with animals'.",
        "input_schema": {
            "type": "object",
            "properties": {
                "query": {
                    "type": "string",
                    "description": "Natural language description of interests, skills, or career goals (e.g., 'I enjoy creative problem solving and working with my hands', 'helping people through difficult times')"
                },
                "top_n": {
                    "type": "integer",
                    "description": "Number of results to return (default 10, max 20)"
                }
            },
            "required": ["query"]
        }
    },
    {
        "name": "read_career_profile",
        "description": "Read the FULL detailed profile for an occupation. Returns comprehensive information including: BLS description, what they do, how to become one, work environment, job outlook, O*NET skills with importance ratings, knowledge areas, Holland Code personality fit, and similar occupations. Use this after search to deeply understand a career before recommending it.",
        "input_schema": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "description": "The occupation code from search results"
                }
            },
            "required": ["code"]
        }
    },
{% endif %}
    {
        "name": "search_occupations",
        "description": "Keyword search for occupations by specific job title or career name. Use semantic_search_careers for natural language queries instead. This tool is best for looking up a SPECIFIC known occupation by name (e.g., 'registered nurse', 'software developer').",
        "input_schema": {
            "type": "object",
            "properties": {
                "query": {
                    "type": "string",
                    "description": "Specific occupation title or keyword (e.g., 'software developer', 'nurse', 'accountant')"
                }
            },
            "required": ["query"]
        }
    },
    {
        "name": "filter_occupations",
        "description": "Filter occupations by criteria like education level, salary range, job outlook, or career category. Use this when a student has specific requirements or constraints.",
        "input_schema": {
            "type": "object",
            "properties": {
                "categories": {
                    "type": "array",
                    "items": {"type": "string"},
                    "description": "Career categories to include (e.g., ['healthcare', 'computer-and-information-technology']). Available: {{ categories | join(', ') }}"
                },
                "min_salary": {
                    "type": "integer",
                    "description": "Minimum annual salary in dollars"
                },
                "max_salary": {
                    "type": "integer",
                    "description": "Maximum annual salary in dollars"
                },
                "education_levels": {
                    "type": "array",
                    "items": {"type": "string"},
                    "description": "Education levels to include (e.g., ['Bachelor\\'s degree', 'High school diploma']). Available: {{ education_levels | join(', ') }}"
                },
                "outlook": {
                    "type": "array",
                    "items": {"type": "string"},
                    "description": "Job outlook categories (e.g., ['Much faster than average', 'Faster than average']). Available: {{ outlook_categories | join(', ') }}"
                }
            },
            "required": []
        }
    },
    {
        "name": "get_occupation_details",
        "description": "Get comprehensive details about a specific occupation including what they do, how to become one, work environment, pay, and job outlook. Use the occupation code from search results.",
        "input_schema": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "description": "The occupation code (e.g., 'B047' for Accountants)"
                }
            },
            "required": ["code"]
        }
    },
    {
        "name": "get_similar_occupations",
        "description": "Get occupations similar to a given one. Use this to help students explore related careers they might not have considered.",
        "input_schema": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "description": "The occupation code to find similar occupations for"
                }
            },
            "required": ["code"]
        }
    },
    {
        "name": "get_state_data",
        "description": "Get state-specific employment and wage data for an occupation. Use this when a student mentions a specific state they want to work in. Returns actual employment counts, median salary for that state, and how it compares to national averages.",
        "input_schema": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "description": "The occupation code to look up"
                },
                "state": {
                    "type": "string",
                    "description": "The state name (e.g., 'Idaho', 'California', 'Texas')"
                }
            },
            "required": ["code", "state"]
        }
    },
    {
        "name": "compare_states",
        "description": "Compare an occupation across multiple states. Use this to help students understand regional differences in employment and wages.",
        "input_schema": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "description": "The occupation code to compare"
                },
                "states": {
                    "type": "array",
                    "items": {"type": "string"},
                    "description": "List of state names to compare (e.g., ['Idaho', 'Utah', 'Washington'])"
                }
            },
            "required": ["code", "states"]
        }
    },
    {
        "name": "get_top_states",
        "description": "Get the states with highest employment for an occupation. Use this to show students where jobs are most plentiful.",
        "input_schema": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "description": "The occupation code to look up"
                },
                "limit": {
                    "type": "integer",
                    "description": "Number of top states to return (default 10)"
                }
            },
            "required": ["code"]
        }
    },
    {
        "name": "get_occupation_skills",
        "description": "Get the key skills and knowledge areas required for an occupation, ranked by importance. Use this when a student asks what skills they need for a career, or to help them understand if their strengths align with an occupation. Data from O*NET.",
        "input_schema": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "description": "The occupation code to look up skills for"
                }
            },
            "required": ["code"]
        }
    },
    {
        "name": "get_occupation_interests",
        "description": "Get the Holland Code interest profile for an occupation. Shows which personality/interest types align best with this career (Realistic, Investigative, Artistic, Social, Enterprising, Conventional). Use this to help students see if a career matches their personality.",
        "input_schema": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "description": "The occupation code to look up interests for"
                }
            },
            "required": ["code"]
        }
    },
    {
        "name": "find_careers_by_skills",
        "description": "Find careers that value specific skills. Use this when a student says they're good at or enjoy certain skills (e.g., 'I'm good at math and problem solving'). Available skills: {{ skill_names | join(', ') }}",
        "input_schema": {
            "type": "object",
            "properties": {
                "skills": {
                    "type": "array",
                    "items": {"type": "string"},
                    "description": "Skills to match against (e.g., ['Mathematics', 'Critical Thinking', 'Programming'])"
                }
            },
            "required": ["skills"]
        }
    },
    {
        "name": "find_careers_by_interests",
        "description": "Find careers matching a student's Holland Code interest profile. Use this when you understand a student's personality type or interests. Rate each of the 6 types from 1 (low) to 7 (high): Realistic (hands-on), Investigative (research/analysis), Artistic (creative), Social (helping people), Enterprising (leading/persuading), Conventional (organizing/data).",
        "input_schema": {
            "type": "object",
            "properties": {
                "realistic": {
                    "type": "number",
                    "description": "Interest in hands-on, practical work (1-7)"
                },
                "investigative": {
                    "type": "number",
                    "description": "Interest in research and problem-solving (1-7)"
                },
                "artistic": {
                    "type": "number",
                    "description": "Interest in creative expression (1-7)"
                },
                "social": {
                    "type": "number",
                    "description": "Interest in helping and teaching others (1-7)"
                },
                "enterprising": {
                    "type": "number",
                    "description": "Interest in leadership and business (1-7)"
                },
                "conventional": {
                    "type": "number",
                    "description": "Interest in organizing and managing data (1-7)"
                }
            },
            "required": ["realistic", "investigative", "artistic", "social", "enterprising", "conventional"]
        }
    }
]
